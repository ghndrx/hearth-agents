# ── Models ──────────────────────────────────────────────────────────────────
MINIMAX_API_KEY=
KIMI_API_KEY=

# ── Research & search ───────────────────────────────────────────────────────
WIKIDELVE_URL=https://wikidelve.walleye-frog.ts.net
SERPER_API_KEY=

# ── Target repos (host dir mounted into agent container at /repos) ──────────
REPOS_DIR=/abs/path/to/parent/of/hearth-repos

# ── Telegram ────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_IDS=

# ── GitHub webhooks ─────────────────────────────────────────────────────────
GITHUB_WEBHOOK_SECRET=

# ── Budget ──────────────────────────────────────────────────────────────────
DAILY_BUDGET_USD=5.0
PER_FEATURE_BUDGET_USD=2.0
MAX_CONCURRENT_SUBAGENTS=3
TELEGRAM_NOTIFY_CHAT_ID=

# ── Loop dials ──────────────────────────────────────────────────────────────
# Workers: higher = more concurrent features in flight; watch disk + Kimi/MiniMax
# rate limits. Fixups: in-loop retries per feature before block. Timeout: wall
# clock per agent.ainvoke call. Bump when block rate is dominated by fixable
# "tests failed" and quota has headroom.
LOOP_WORKERS=6
MAX_FIXUPS=6
PER_FEATURE_TIMEOUT_SEC=900

# ── Langfuse observability ──────────────────────────────────────────────────
# Self-hosted via docker-compose (langfuse-web + langfuse-postgres services).
# After first boot, create an org + project in the Langfuse UI, then paste the
# API keys below. Empty keys disable tracing entirely (graceful default).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://langfuse-web:3000
# These two seed the Langfuse deployment itself, NOT the agent. Rotate them
# once the stack is initialized; changing SALT after accounts exist requires
# a DB wipe.
LANGFUSE_NEXTAUTH_SECRET=
LANGFUSE_SALT=
LANGFUSE_NEXTAUTH_URL=https://langfuse.walleye-frog.ts.net

# ── Public hostnames (Tailscale serve) ──────────────────────────────────────
HEARTH_AGENTS_PUBLIC_URL=https://hearth-agents.walleye-frog.ts.net
LANGFUSE_PUBLIC_URL=https://langfuse.walleye-frog.ts.net
