#!/usr/bin/env python3
"""hearth — CLI wrapper around the hearth-agents HTTP API.

Usage:
  hearth status                              # /stats summary
  hearth features [--status=X] [--kind=Y] [--query='kind:bug AND heal_attempts>=2']
  hearth show <feature_id>                   # full feature + recent history
  hearth queue <id> <name> <description>     # POST /features
  hearth bug <id> <name> <repro> <desc>      # POST /features kind=bug
  hearth approve|retry|nuke <id>             # POST /features/{id}/action
  hearth debate <id>                         # POST /features/{id}/debate
  hearth cost                                # /cost-analytics + forecast
  hearth who                                 # active workers
  hearth health                              # /health with subsystem status
  hearth dep <id>                            # deps + blocked-by
  hearth tail                                # last 20 transitions

Env:
  HEARTH_URL  base URL (default https://hearth.walleye-frog.ts.net)
"""

from __future__ import annotations

import json
import os
import sys
import urllib.request
import urllib.parse
import urllib.error


BASE = os.environ.get("HEARTH_URL", "https://hearth.walleye-frog.ts.net").rstrip("/")


def _req(method: str, path: str, body: dict | None = None, params: dict | None = None):
    url = BASE + path
    if params:
        url += "?" + urllib.parse.urlencode({k: v for k, v in params.items() if v is not None})
    data = json.dumps(body).encode() if body is not None else None
    headers = {"Content-Type": "application/json"} if data else {}
    req = urllib.request.Request(url, data=data, headers=headers, method=method)
    try:
        with urllib.request.urlopen(req, timeout=30) as r:
            return json.loads(r.read())
    except urllib.error.HTTPError as e:
        print(f"HTTP {e.code}: {e.read().decode()[:400]}", file=sys.stderr)
        sys.exit(1)


def cmd_status(args: list[str]) -> None:
    d = _req("GET", "/stats")
    print(f"backlog: {d['stats']}")
    print(f"recent_24h: done={d['recent_24h']['done']} blocked={d['recent_24h']['blocked']}")
    for r in d.get("block_reasons_top10", [])[:5]:
        print(f"  {r['count']}× {r['reason'][:80]}")


def cmd_features(args: list[str]) -> None:
    params = {}
    for a in args:
        if a.startswith("--status="): params["status"] = a.split("=", 1)[1]
        elif a.startswith("--kind="): params["kind"] = a.split("=", 1)[1]
        elif a.startswith("--query="): params["query"] = a.split("=", 1)[1]
        elif a.startswith("--q="): params["q"] = a.split("=", 1)[1]
    rows = _req("GET", "/features", params=params)
    for f in rows[:80]:
        mark = "●" if f["status"] == "done" else "○" if f["status"] == "pending" else "◐"
        print(f"  {mark} [{f['status']:12s}] {f['priority']:8s} {f['kind']:10s} {f['id']}: {f['name'][:60]}")
    print(f"\n{len(rows)} shown")


def cmd_show(args: list[str]) -> None:
    if not args:
        print("usage: hearth show <feature_id>", file=sys.stderr); sys.exit(2)
    h = _req("GET", f"/features/{urllib.parse.quote(args[0])}/history")
    f = h.get("feature") or {}
    print(f"{f.get('id')}: {f.get('name')}")
    print(f"  status={f.get('status')} kind={f.get('kind')} priority={f.get('priority')} heal_attempts={f.get('heal_attempts')}")
    if f.get('depends_on'): print(f"  deps: {', '.join(f['depends_on'])}")
    if f.get('heal_hint'): print(f"  hint: {f['heal_hint'][:200]}")
    print(f"\nrecent transitions ({len(h.get('transitions', []))} total):")
    for t in (h.get("transitions") or [])[-5:]:
        print(f"  {t.get('ts')} {t.get('from','-')} → {t.get('to')} [{t.get('actor','?')}] {(t.get('reason','') or '')[:60]}")


def cmd_queue(args: list[str]) -> None:
    if len(args) < 3:
        print("usage: hearth queue <id> <name> <description>", file=sys.stderr); sys.exit(2)
    r = _req("POST", "/features", body={"id": args[0], "name": args[1], "description": args[2]})
    print(f"queued: {r}")


def cmd_bug(args: list[str]) -> None:
    if len(args) < 4:
        print("usage: hearth bug <id> <name> <repro_cmd> <description>", file=sys.stderr); sys.exit(2)
    r = _req("POST", "/features", body={
        "id": args[0], "name": args[1], "description": args[3],
        "kind": "bug", "repro_command": args[2], "priority": "high",
    })
    print(f"queued bug: {r}")


def cmd_action(action: str, args: list[str]) -> None:
    if not args:
        print(f"usage: hearth {action} <feature_id>", file=sys.stderr); sys.exit(2)
    r = _req("POST", f"/features/{urllib.parse.quote(args[0])}/action", body={"action": action})
    print(r)


def cmd_debate(args: list[str]) -> None:
    if not args:
        print("usage: hearth debate <feature_id>", file=sys.stderr); sys.exit(2)
    r = _req("POST", f"/features/{urllib.parse.quote(args[0])}/debate")
    for item in r.get("results", []):
        print(f"  {item.get('tag')}: {item.get('tool_count', 0)} tools · {item.get('input_tokens', 0)}in/{item.get('output_tokens', 0)}out")


def cmd_cost(args: list[str]) -> None:
    d = _req("GET", "/cost-analytics")
    f = _req("GET", "/cost-analytics/forecast")
    print(f"total: ${d['total_cost_usd']:.4f}  (in:{d['total_input_tokens']:,} out:{d['total_output_tokens']:,})")
    print(f"p50 duration: {d['duration_percentiles']['p50']}s · p95: {d['duration_percentiles']['p95']}s")
    print(f"month-to-date: ${f['month_to_date_usd']:.4f}  forecast: ${f['forecast_usd']:.4f} (avg ${f['trend_avg_daily_usd']:.4f}/d)")


def cmd_who(args: list[str]) -> None:
    d = _req("GET", "/stats")
    for wid, info in (d.get("workers") or {}).items():
        print(f"  w{wid}: {info['feature']} ({info['age_sec']}s ago)")


def cmd_health(args: list[str]) -> None:
    h = _req("GET", "/health")
    print(f"status: {h['status']}")
    for name, info in h.get("subsystems", {}).items():
        mark = "✗" if info['stale'] else "✓"
        age = "never" if info['age_sec'] < 0 else f"{info['age_sec']}s ago"
        print(f"  {mark} {name}: {age}")


def cmd_dep(args: list[str]) -> None:
    if not args:
        print("usage: hearth dep <feature_id>", file=sys.stderr); sys.exit(2)
    h = _req("GET", f"/features/{urllib.parse.quote(args[0])}/history")
    f = h.get("feature") or {}
    deps = f.get("depends_on") or []
    print(f"{args[0]}: deps={deps or '(none)'}")
    if deps:
        feats = _req("GET", "/features")
        lookup = {x["id"]: x for x in feats}
        for d in deps:
            fd = lookup.get(d, {})
            mark = "✓" if fd.get("status") == "done" else "○"
            print(f"  {mark} {d}: {fd.get('status', '(missing from backlog)')}")


def cmd_tail(args: list[str]) -> None:
    limit = int(args[0]) if args else 20
    rows = _req("GET", "/transitions", params={"limit": limit})
    for t in rows:
        print(f"  {t.get('ts')} {t.get('feature_id','?'):40s} {t.get('from','-')} → {t.get('to')} [{t.get('actor','?')}]")


def cmd_deploy(args: list[str]) -> None:
    """Safe deploy: git pull → build (captured) → up → verify /health.
    On build failure OR post-swap /health degraded, surface clearly
    instead of returning green. Requires SSH to gateway-01 configured
    via HEARTH_SSH_HOST (default administrator@gateway-01)."""
    import subprocess
    host = os.environ.get("HEARTH_SSH_HOST", "administrator@gateway-01")
    remote_dir = os.environ.get("HEARTH_REMOTE_DIR", "/opt/hearth-agents")
    ssh_key = os.environ.get("HEARTH_SSH_KEY", os.path.expanduser("~/.ssh/macaroni"))
    ssh_cmd = ["ssh", "-i", ssh_key, host]

    def _ssh(cmdline: str, timeout: int = 300) -> tuple[int, str]:
        r = subprocess.run(
            ssh_cmd + [cmdline], capture_output=True, text=True,
            timeout=timeout, check=False,
        )
        return r.returncode, (r.stdout + r.stderr)

    print("=> pulling")
    rc, out = _ssh(f"cd {remote_dir} && git pull --ff-only origin main")
    if rc != 0:
        print(f"pull failed ({rc}):\n{out[-1000:]}", file=sys.stderr); sys.exit(1)
    print(out.strip().split("\n")[-1])

    # Fetch git sha + branch to stamp into the image.
    sha_rc, sha_out = _ssh(f"cd {remote_dir} && git rev-parse --short HEAD && git rev-parse --abbrev-ref HEAD")
    git_sha = "unknown"
    git_branch = "unknown"
    if sha_rc == 0:
        parts = sha_out.strip().splitlines()
        if len(parts) >= 2:
            git_sha, git_branch = parts[0].strip(), parts[1].strip()

    print(f"=> building {git_sha}@{git_branch} (this can take a few minutes)")
    rc, out = _ssh(
        f"cd {remote_dir} && GIT_SHA={git_sha} GIT_BRANCH={git_branch} "
        f"docker compose build --build-arg GIT_SHA={git_sha} --build-arg GIT_BRANCH={git_branch} agent",
        timeout=900,
    )
    if rc != 0 or "failed to solve" in out or "ERROR" in out:
        err = "\n".join(line for line in out.splitlines() if any(s in line for s in ("ERROR", "failed", "error:")))
        print(f"build failed:\n{err[-2000:]}", file=sys.stderr); sys.exit(2)
    print("build ok")

    print("=> swapping container")
    rc, out = _ssh(f"cd {remote_dir} && docker compose up -d agent")
    if rc != 0:
        print(f"swap failed ({rc}):\n{out[-1000:]}", file=sys.stderr); sys.exit(3)

    print("=> waiting for /health")
    import time
    for i in range(24):  # 2-minute window
        time.sleep(5)
        try:
            h = _req("GET", "/health")
            if h.get("status") == "ok":
                print(f"✓ deploy complete — status=ok, stats={h.get('stats')}")
                return
            print(f"  … waiting (status={h.get('status','?')})")
        except SystemExit:
            pass
        except Exception as e:
            print(f"  … waiting ({e})")
    print("deploy didn't reach status=ok within 2m — check /health manually", file=sys.stderr)
    sys.exit(4)


def cmd_forecast(args: list[str]) -> None:
    f = _req("GET", "/cost-analytics/forecast")
    print(f"month-to-date: ${f.get('month_to_date_usd', 0):.4f}")
    print(f"trend:         ${f.get('trend_avg_daily_usd', 0):.4f}/d over {f.get('trend_sample_days', 0)}d")
    print(f"forecast eom:  ${f.get('forecast_usd', 0):.4f}  ({f.get('end_of_month_days_ahead', 0)}d ahead)")


def cmd_dashboard(args: list[str]) -> None:
    repo = args[0] if args else "hearth"
    d = _req("GET", f"/dashboard/{urllib.parse.quote(repo)}")
    print(f"{repo}: total={d.get('total')} · by_status={d.get('by_status')}")
    r = d.get("recent_24h", {})
    print(f"  24h: done={r.get('done')} blocked={r.get('blocked')} total={r.get('total')}")
    for br in (d.get("top_block_reasons") or [])[:5]:
        print(f"  {br['count']}× {br['reason'][:60]}")


def cmd_synth(args: list[str]) -> None:
    if not args:
        print("usage: hearth synth <slug> [kb=personal]", file=sys.stderr); sys.exit(2)
    slug = args[0]
    kb = "personal"
    for a in args[1:]:
        if a.startswith("kb="): kb = a.split("=", 1)[1]
    print(f"synthesizing {kb}/{slug}... (~20s)")
    r = _req("POST", "/research/synthesize", body={"kb": kb, "slug": slug})
    if r.get("summary"):
        print(f"\n{r['summary']}\n")
    for i, rec in enumerate(r.get("recommendations", []), 1):
        print(f"{i}. {rec.get('title','?')} ({rec.get('leverage','?')})")
        print(f"   {rec.get('change_sketch','')}")
        if rec.get("touches"):
            print(f"   touches: {', '.join(rec['touches'])}")
    skip = r.get("skip_reasons") or []
    if skip:
        print(f"\nskipped: {skip}")


def cmd_export(args: list[str]) -> None:
    """Dump full backlog as JSON to stdout."""
    rows = _req("GET", "/backlog/export")
    print(json.dumps(rows, indent=2))


def cmd_search(args: list[str]) -> None:
    if not args:
        print("usage: hearth search <query-dsl>", file=sys.stderr); sys.exit(2)
    rows = _req("GET", "/features", params={"query": " ".join(args), "limit": 50})
    for f in rows:
        mark = "●" if f["status"] == "done" else "○" if f["status"] == "pending" else "◐"
        print(f"  {mark} [{f['status']:12s}] {f['priority']:8s} {f['kind']:10s} {f['id']}: {f['name'][:60]}")
    print(f"\n{len(rows)} shown")


def cmd_build(args: list[str]) -> None:
    b = _req("GET", "/build")
    for k, v in b.items():
        print(f"  {k}: {v}")


def cmd_read_only(args: list[str]) -> None:
    """hearth read-only [on|off] — toggle loop quiesce."""
    if not args:
        r = _req("POST", "/admin/read-only", body={})
        print(f"read_only: {r.get('read_only')}")
        return
    on = args[0].lower() in ("on", "true", "yes", "1", "enable")
    r = _req("POST", "/admin/read-only", body={"enabled": on})
    print(f"read_only: {r.get('read_only')} (was {r.get('previous')})")


def cmd_validate(args: list[str]) -> None:
    v = _req("GET", "/backlog/validate")
    print(f"features: {v['total_features']} · problems: {v['problem_count']} · healthy: {v['healthy']}")
    for p in v.get("problems", [])[:20]:
        print(f"  {p['id']}: {', '.join(p['issues'])}")


def cmd_debug(args: list[str]) -> None:
    """One-shot drill-down for a feature: current state + history +
    recent attempts + similar features. Human-readable, pipe-friendly."""
    if not args:
        print("usage: hearth debug <feature_id>", file=sys.stderr); sys.exit(2)
    fid = args[0]
    print(f"=== {fid} ===\n")
    h = _req("GET", f"/features/{urllib.parse.quote(fid)}/history")
    f = h.get("feature") or {}
    if not f:
        print(f"(not found)"); return
    print(f"status={f.get('status')} kind={f.get('kind')} priority={f.get('priority')} "
          f"heal={f.get('heal_attempts')}/3 risk={f.get('risk_tier','low')}")
    if f.get("depends_on"):
        print(f"depends_on: {', '.join(f['depends_on'])}")
    if f.get("heal_hint"):
        print(f"hint: {f['heal_hint'][:300]}")
    print(f"name: {f.get('name','')}")
    print(f"description: {(f.get('description') or '')[:300]}")
    print(f"\n--- transitions (last 8 of {len(h.get('transitions',[]))}) ---")
    for t in (h.get("transitions") or [])[-8:]:
        print(f"  {t.get('ts')} {t.get('from','-')} → {t.get('to')} [{t.get('actor','?')}] {(t.get('reason','') or '')[:60]}")
    print(f"\n--- attempts ---")
    attempts = _req("GET", f"/features/{urllib.parse.quote(fid)}/attempts", params={"limit": 10})
    for a in attempts:
        dur = a.get("duration_sec") or 0
        print(f"  #{a.get('attempt')} [{a.get('provider','?')}] {a.get('input_tokens',0)}in/{a.get('output_tokens',0)}out · {dur}s · {len(a.get('tool_calls') or [])} tool calls")
    print(f"\n--- similar ---")
    sim = _req("GET", f"/features/{urllib.parse.quote(fid)}/similar", params={"limit": 5})
    for s in sim:
        print(f"  {s.get('similarity',0):.2f}  [{s.get('status','?')}] {s.get('id','?')}: {s.get('name','')[:60]}")


def cmd_top(args: list[str]) -> None:
    """Live htop-style dashboard: backlog stats, active workers with
    beat age + last error, today's spend + block-rate, updated every
    5s. Ctrl-c to exit."""
    import time
    while True:
        try:
            stats = _req("GET", "/stats")
            cost = _req("GET", "/cost-analytics")
            cfg = _req("GET", "/config")
            # ANSI clear-screen + home.
            sys.stdout.write("\x1b[2J\x1b[H")
            sys.stdout.write("hearth top · ctrl-c to exit\n\n")
            sys.stdout.write(f"prompts: {cfg.get('prompts_version','?')}  workers: {cfg.get('loop',{}).get('workers','?')}/{cfg.get('loop',{}).get('workers_max','?')}\n\n")
            s = stats.get("stats", {})
            sys.stdout.write(f"backlog: done={s.get('done',0):4d}  pending={s.get('pending',0):3d}  implementing={s.get('implementing',0):2d}  blocked={s.get('blocked',0):3d}\n")
            r24 = stats.get("recent_24h", {})
            br = (r24.get("blocked") or 0) / max(1, (r24.get("done", 0) or 0) + (r24.get("blocked", 0) or 0)) * 100
            sys.stdout.write(f"24h:     done={r24.get('done',0):4d}  blocked={r24.get('blocked',0):3d}  block_rate={br:.1f}%\n\n")
            sys.stdout.write(f"spend:   ${cost.get('total_cost_usd',0):.4f} total  p50 {cost.get('duration_percentiles',{}).get('p50',0)}s  p95 {cost.get('duration_percentiles',{}).get('p95',0)}s\n\n")
            workers = stats.get("workers") or {}
            sys.stdout.write(f"workers ({len(workers)} active):\n")
            for wid, info in sorted(workers.items(), key=lambda kv: int(kv[0])):
                age = info.get("age_sec", 0)
                color = "\x1b[32m" if age < 120 else "\x1b[33m" if age < 600 else "\x1b[31m"
                sys.stdout.write(f"  {color}w{wid}\x1b[0m beat {age:4d}s  feature: {info.get('feature','-')}\n")
                err = info.get("last_error")
                if err:
                    sys.stdout.write(f"        last_err({err.get('age_sec',0)}s ago on {err.get('feature_id','?')}): {err.get('error','')[:80]}\n")
            sys.stdout.write("\n")
            reasons = stats.get("block_reasons_top10") or []
            if reasons:
                sys.stdout.write("top blocks:\n")
                for r in reasons[:5]:
                    sys.stdout.write(f"  {r['count']:3d}×  {r['reason'][:70]}\n")
            sys.stdout.flush()
            time.sleep(5)
        except KeyboardInterrupt:
            sys.stdout.write("\n")
            return
        except Exception as e:
            sys.stdout.write(f"\nerror: {e} — retrying in 5s\n")
            time.sleep(5)


def cmd_watch(args: list[str]) -> None:
    """Tail /events. Prints one human-readable line per transition.
    Reconnects automatically on drop. Use ctrl-c to exit."""
    import time
    import http.client
    from urllib.parse import urlparse
    url = urlparse(BASE + "/events")
    is_https = url.scheme == "https"
    while True:
        try:
            conn_cls = http.client.HTTPSConnection if is_https else http.client.HTTPConnection
            conn = conn_cls(url.netloc, timeout=30)
            conn.request("GET", url.path, headers={"Accept": "text/event-stream"})
            resp = conn.getresponse()
            if resp.status != 200:
                print(f"SSE returned {resp.status}; retry in 5s", file=sys.stderr)
                time.sleep(5); continue
            print(f"# tailing {url.geturl()} — ctrl-c to exit")
            buf = ""
            while True:
                chunk = resp.read(1)
                if not chunk:
                    break
                buf += chunk.decode(errors="replace")
                while "\n" in buf:
                    line, buf = buf.split("\n", 1)
                    line = line.rstrip("\r")
                    if line.startswith("data:"):
                        try:
                            e = json.loads(line[5:].strip())
                            ts = e.get("ts", "")[11:19]
                            print(f"  {ts} {e.get('feature_id','?'):35s} {e.get('from','-')} → {e.get('to')} [{e.get('actor','?')}]")
                        except json.JSONDecodeError:
                            pass
        except KeyboardInterrupt:
            return
        except Exception as e:
            print(f"# disconnected ({e}); reconnecting in 5s", file=sys.stderr)
            time.sleep(5)


def cmd_bulk(args: list[str]) -> None:
    """hearth bulk <action> <query-dsl> — bulk-action by query."""
    if len(args) < 2:
        print("usage: hearth bulk <approve|retry|nuke|fresh_retry> <query-dsl>", file=sys.stderr); sys.exit(2)
    action = args[0]
    query = " ".join(args[1:])
    # Always do dry-run first.
    dry = _req("POST", "/features/bulk-action", body={"query": query, "action": action, "dry_run": True})
    ids = dry.get("ids") or []
    print(f"matched {dry.get('matched', 0)} features: {', '.join(ids[:10])}{'...' if len(ids) > 10 else ''}")
    if not ids:
        return
    confirm = input(f"Apply {action} to all {len(ids)}? [y/N] ").strip().lower()
    if confirm != "y":
        print("aborted"); return
    out = _req("POST", "/features/bulk-action", body={"query": query, "action": action, "dry_run": False})
    ok = sum(1 for r in out.get("results", []) if r.get("ok"))
    print(f"{action}: {ok}/{out.get('count', 0)} ok")


COMMANDS = {
    "status": cmd_status, "features": cmd_features, "show": cmd_show,
    "queue": cmd_queue, "bug": cmd_bug,
    "approve": lambda a: cmd_action("approve", a),
    "retry": lambda a: cmd_action("retry", a),
    "nuke": lambda a: cmd_action("nuke", a),
    "debate": cmd_debate, "cost": cmd_cost,
    "who": cmd_who, "health": cmd_health, "dep": cmd_dep, "tail": cmd_tail,
    "deploy": cmd_deploy,
    "forecast": cmd_forecast, "dashboard": cmd_dashboard, "synth": cmd_synth,
    "export": cmd_export, "search": cmd_search, "build": cmd_build, "bulk": cmd_bulk,
    "read-only": cmd_read_only, "validate": cmd_validate, "watch": cmd_watch,
    "top": cmd_top, "debug": cmd_debug,
}


def main() -> None:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__); sys.exit(0 if len(sys.argv) > 1 and sys.argv[1] in ("-h","--help","help") else 2)
    cmd = sys.argv[1]
    handler = COMMANDS.get(cmd)
    if handler is None:
        print(f"unknown command: {cmd}\nRun 'hearth help' for usage.", file=sys.stderr); sys.exit(2)
    handler(sys.argv[2:])


if __name__ == "__main__":
    main()
